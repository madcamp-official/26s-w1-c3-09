# ============================================================
# madfinder 환경변수 목록 (server + batch 공용)
# 사용법: 이 파일을 복사해 .env 로 만들고 값을 채운다 (.env는 git 제외)
#         또는 OS 환경변수로 직접 등록
# ============================================================

# 주의: 안 쓰는 변수는 빈 값(X) 대신 주석(O)으로 둘 것 —
#       .env가 자동 로드되므로 빈 값이 기본값을 빈 문자열로 덮어써 접속이 깨진다.

# MySQL 접속 호스트 (기본값 localhost — 바꿀 때만 주석 해제)
# Docker 배포 시 compose가 mysql 컨테이너 이름을 주입
#DB_HOST=localhost

# MySQL root 비밀번호 (각자 자기 것 — 필수)
DB_PASSWORD=

# (선택) F-10 유튜브 영상 기능 사용 시
#YOUTUBE_API_KEY=
